<?xml version="1.0"?>
<info xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="https://apps.nextcloud.com/schema/apps/info.xsd">
    <id>neura_google_calendar_sync</id>
    <namespace>NeuraGoogleCalendarSync</namespace>
    <name>Google Workspace Calendar Sync</name>
    <summary>Bidirectional Google Workspace calendar sync via domain Service Account</summary>
    <description>Syncs all Nextcloud calendars with Google Calendar for every domain user using a Google Service Account with Domain-Wide Delegation.</description>
    <version>1.0.0</version>
    <licence>agpl</licence>
    <author mail="opensource@ianustec.com" homepage="https://ianustec.com">IANUSTEC</author>
    <website>https://github.com/ianustec/nextcloud-google-calendar-sync</website>
    <bugs>https://github.com/ianustec/nextcloud-google-calendar-sync/issues</bugs>
    <category>organization</category>
    <dependencies>
        <nextcloud min-version="27" max-version="32"/>
        <dav min-version="1"/>
    </dependencies>
    <background-jobs>
        <job>OCA\NeuraGoogleCalendarSync\Cron\CalendarSyncJob</job>
    </background-jobs>
    <settings>
        <admin-section>OCA\NeuraGoogleCalendarSync\Settings\AdminSection</admin-section>
        <admin>OCA\NeuraGoogleCalendarSync\Settings\AdminSettings</admin>
    </settings>
</info>
